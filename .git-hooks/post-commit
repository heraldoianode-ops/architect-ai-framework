#!/bin/bash
# ARCHITECT-AI — post-commit hook
# ES: Actualiza health.json automáticamente después de cada commit
# EN: Automatically updates health.json after each commit

CORE_DIR="__AI_CORE__"

if [ ! -f "$CORE_DIR/health.json" ]; then exit 0; fi

python3 -c "
import json, subprocess, datetime, os

core = '$CORE_DIR'

def load(f):
    try:
        return json.load(open(f'{core}/{f}'))
    except:
        return {}

health   = load('health.json')
debt     = load('tech_debt.json')
features = load('features.json')
config   = load('config.json')

debts = debt.get('debts', [])
critical = sum(1 for d in debts if d.get('status') == 'OPEN' and d.get('severity') == 'CRITICAL')
high     = sum(1 for d in debts if d.get('status') == 'OPEN' and d.get('severity') == 'HIGH')
medium   = sum(1 for d in debts if d.get('status') == 'OPEN' and d.get('severity') == 'MEDIUM')
low      = sum(1 for d in debts if d.get('status') == 'OPEN' and d.get('severity') == 'LOW')
debt_score = min(100, critical * 30 + high * 15 + medium * 5 + low * 1)

phases = config.get('roadmap', {}).get('phases', [])
complete = sum(1 for p in phases if p.get('status') == 'COMPLETE')
total = len(phases)
pct = config.get('roadmap', {}).get('progress_pct', 0)

if critical > 0 or debt_score > 60:
    status = 'CRITICAL'
elif high > 2 or debt_score > 30:
    status = 'WARNING'
else:
    status = 'HEALTHY'

alerts = []
if critical > 0:
    alerts.append({'level': 'CRITICAL', 'msg_es': f'{critical} deuda(s) crítica(s) abiertas', 'msg_en': f'{critical} open critical debt(s)'})
if high > 2:
    alerts.append({'level': 'HIGH', 'msg_es': f'{high} deudas HIGH — considerar sesión de deuda', 'msg_en': f'{high} HIGH debts — consider debt session'})

health['last_calculated'] = datetime.datetime.now().isoformat()
health['overall_score']   = debt_score
health['status']          = status
health['dimensions']['debt'] = {
    'critical_count': critical, 'high_count': high,
    'medium_count': medium, 'low_count': low, 'value': debt_score
}
health['dimensions']['progress'] = {
    'phases_complete': complete, 'phases_total': total, 'pct': pct
}
health['alerts'] = alerts

with open(f'{core}/health.json', 'w') as f:
    json.dump(health, f, indent=2, ensure_ascii=False)

if status == 'CRITICAL':
    print(f'\033[0;31m⚠️  SALUD CRÍTICA — {critical} deuda(s) crítica(s). Revisar antes de continuar.\033[0m')
elif status == 'WARNING':
    print(f'\033[1;33m⚠️  SALUD WARNING — {high} deudas HIGH activas.\033[0m')
" 2>/dev/null || true
