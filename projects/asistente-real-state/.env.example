# ─── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=asistente_real_state
POSTGRES_USER=ars_user
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://ars_user:change_me_strong_password@postgres:5432/asistente_real_state

# ─── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

# ─── AI Policy ──────────────────────────────────────────────────
# Default: false — all LLM calls use Ollama local (zero cost)
# Set to true ONLY to enable external LLM for authorized agents
ALLOW_EXTERNAL_LLM=false

OLLAMA_BASE_URL=http://ollama:11434

# External LLM (only used when ALLOW_EXTERNAL_LLM=true)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Auth ───────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_min_32_chars

# ─── Supabase (auth + storage) ──────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── WhatsApp Business API ──────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change_me_verify_token
WHATSAPP_APP_SECRET=

# ─── Google ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email ──────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Monitoring ─────────────────────────────────────────────────
SENTRY_DSN=

# ─── App ────────────────────────────────────────────────────────
ENVIRONMENT=development
